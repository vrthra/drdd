#!/usr/bin/env python3
"""Minimize a binary file using a DD-family algorithm and an FFmpeg ASAN oracle."""

import argparse
import sys
import tomllib

from pathlib         import Path
from algos           import ALGORITHMS
from utils.fmt       import fmt_bytes
from drivers.ffmpeg  import ffmpeg_minimizer
from drivers.logging import MinimizerLog


def main():
	p = argparse.ArgumentParser(description=__doc__)

	p.add_argument("predicate",
		type = Path,
		help = "Path to predicate directory",
	)
	p.add_argument("--algorithm",
		default = "ddmin",
		choices = ALGORITHMS,
		help    = "Algorithm to use (default: ddmin)",
	)
	p.add_argument("--input",
		default = "input",
		help    = "Input file rel. to predicate directory (default: input)",
	)
	p.add_argument("--output",
		default = "input.min",
		help    = "Output file rel. to predicate directory (default: input.min)",
	)
	p.add_argument("--verbose",
		action = "store_true",
		help   = "Print minimizer progress log",
	)

	args = p.parse_args()
	
	base_path   = args.predicate.resolve()
	input_path  = base_path / args.input
	config_path = base_path / "config.toml"
	out_path    = base_path / args.output

	if not input_path.exists():  p.error(f"Input file not found: {input_path}")
	if not config_path.exists(): p.error(f"config.toml not found: {config_path}")

	try: config = tomllib.loads(config_path.read_text())
	except tomllib.TOMLDecodeError as e: p.error(f"Invalid config.toml: {e}")

	for key in ("commit", "filter", "target"):
		if key not in config: p.error(f"Missing '{key}' in {config_path}")

	ffmpeg_path = base_path.parent / "lib" / f"ffmpeg_g-{config['commit']}"
	if not ffmpeg_path.exists(): p.error(f"FFmpeg binary not found: {ffmpeg_path}")

	try:
		result = ffmpeg_minimizer(

			input_path  = input_path,
			output_path = out_path,
			algorithm   = args.algorithm,
			ffmpeg_path = ffmpeg_path,
			filter_expr = config["filter"],
			target      = config["target"],
			log         = MinimizerLog(interval=5.0) if args.verbose else None,

		)

		if args.verbose:
			summary = (

				f"\n - Minimized : {fmt_bytes(result['minimized_length'])}"
				f"\n - Oracle    : {result['oracle_invocations']} invocations"
				f"\n - Output    : {out_path}"

			)
			
			print(summary)

		else: print(f"Wrote minimized file to: {out_path}")

	except (FileNotFoundError, ValueError, OSError) as e: p.error(str(e))

	except KeyboardInterrupt:
		if args.verbose: print("\n\nInterrupted by user (130)", file=sys.stderr)
		sys.exit(130)


if __name__ == "__main__":
	main()
